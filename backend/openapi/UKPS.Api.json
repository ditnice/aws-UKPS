{
  "openapi": "3.1.1",
  "info": {
    "title": "UKPS.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/organisations/{id}": {
      "get": {
        "tags": [
          "Organisation"
        ],
        "summary": "Retrieves an organisation by its unique identifier.",
        "operationId": "GetOrganisationById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The identifier of the organisation to retrieve.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The organisation was found and its details were returned.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              }
            }
          },
          "404": {
            "description": "No organisation exists with the specified identifier.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Organisation"
        ],
        "summary": "Updates the details of an existing organisation.",
        "operationId": "UpdateOrganisationDetails",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The identifier of the organisation to update.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "A token that can be used to cancel the operation.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationDetailsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationDetailsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationDetailsDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The organisation was successfully updated.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationDetailsDto"
                }
              }
            }
          },
          "400": {
            "description": "The supplied organisation details failed validation.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "No organisation exists with the specified identifier.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/organisations/{organisationId}/memberships/{membershipId}/deactivate": {
      "patch": {
        "tags": [
          "Organisation"
        ],
        "summary": "Deactivates an organisation membership.",
        "operationId": "DeactivateMembership",
        "parameters": [
          {
            "name": "organisationId",
            "in": "path",
            "description": "The identifier of the organisation that owns the membership.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "membershipId",
            "in": "path",
            "description": "The identifier of the membership to deactivate.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The membership was successfully deactivated.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "The specified organisation membership could not be found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/organisations/{organisationId}/memberships/{membershipId}/update-role": {
      "patch": {
        "tags": [
          "Organisation"
        ],
        "summary": "Updates the role assigned to a user within an organisation membership.",
        "operationId": "UpdateUserRole",
        "parameters": [
          {
            "name": "organisationId",
            "in": "path",
            "description": "The identifier of the organisation that owns the membership.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "membershipId",
            "in": "path",
            "description": "The identifier of the membership to update.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "A token that can be used to cancel the operation.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrgMembershipUserRoleCommandDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrgMembershipUserRoleCommandDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrgMembershipUserRoleCommandDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The membership role was successfully updated.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationMembershipDto"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "The specified organisation membership could not be found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Retrieves a paginated list of users based on the specified query parameters.",
        "operationId": "GetUsers",
        "parameters": [
          {
            "name": "OrganisationId",
            "in": "query",
            "description": "Gets or initialises the optional ID of the organisation to filter users by.",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "Page",
            "in": "query",
            "description": "Gets or initialises the page number for pagination.\nMust be greater than or equal to 1.",
            "schema": {
              "maximum": 2147483647,
              "minimum": 1,
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "description": "Gets or initialises the number of items per page for pagination.\nMust be between 1 and 100.",
            "schema": {
              "maximum": 100,
              "minimum": 1,
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "description": "Gets or initialises the collection of user organisation statuses to filter users by.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/UserOrgStatus"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the paginated list of users.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseDtoOfUserListItemDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseDtoOfUserListItemDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseDtoOfUserListItemDto"
                }
              }
            }
          },
          "400": {
            "description": "Returned if the query parameters are invalid or the organisation is not found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Returned if no users are found matching the query parameters.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrganisationDetailsDto": {
        "required": [
          "organisationName",
          "headOfficeAddress",
          "headOfficeEmail",
          "headOfficeTelephone"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the unique identifier of the organisation.",
            "format": "int32"
          },
          "organisationName": {
            "type": "string",
            "description": "Gets the name of the organisation."
          },
          "organisationType": {
            "description": "Gets the type of the organisation.",
            "$ref": "#/components/schemas/OrganisationType"
          },
          "allowedPharmaceuticalEntity": {
            "description": "Gets the allowed pharmaceutical entity for the organisation.",
            "$ref": "#/components/schemas/PharmaceuticalEntity"
          },
          "countryOrRegion": {
            "type": [
              "null",
              "string"
            ],
            "description": "Gets the country or region where the organisation is located."
          },
          "headOfficeAddress": {
            "type": "string",
            "description": "Gets the address of the organisation's head office."
          },
          "headOfficeEmail": {
            "type": "string",
            "description": "Gets the email address of the organisation's head office."
          },
          "headOfficeTelephone": {
            "type": "string",
            "description": "Gets the telephone number of the organisation's head office."
          },
          "status": {
            "description": "Gets the current status of the organisation.",
            "$ref": "#/components/schemas/UserOrgStatus"
          },
          "lastActive": {
            "type": [
              "null",
              "string"
            ],
            "description": "Gets the date and time when the organisation was last active.",
            "format": "date-time"
          },
          "createdAt": {
            "type": [
              "null",
              "string"
            ],
            "description": "Gets the date and time when the organisation was created.",
            "format": "date-time"
          }
        },
        "description": "Represents the details of an organisation."
      },
      "OrganisationMembershipDto": {
        "required": [
          "id",
          "userId",
          "organisationId",
          "userRole",
          "status",
          "allowedPharmaceuticalEntity",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the unique identifier of the organisation membership.",
            "format": "int32"
          },
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the unique identifier of the user associated with the membership.",
            "format": "int32"
          },
          "organisationId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the unique identifier of the organisation associated with the membership.",
            "format": "int32"
          },
          "userRole": {
            "description": "Gets the role of the user within the organisation.",
            "$ref": "#/components/schemas/UserRole"
          },
          "status": {
            "description": "Gets the status of the user within the organisation.",
            "$ref": "#/components/schemas/UserOrgStatus"
          },
          "allowedPharmaceuticalEntity": {
            "description": "Gets the pharmaceutical entity that the user is allowed to access.",
            "$ref": "#/components/schemas/PharmaceuticalEntity"
          },
          "createdAt": {
            "type": "string",
            "description": "Gets the date and time when the organisation membership was created.",
            "format": "date-time"
          }
        },
        "description": "Represents the data transfer object for an organisation membership."
      },
      "OrganisationType": {
        "enum": [
          "PharmaCompany",
          "HorizonScanning",
          "Strategic",
          "Internal"
        ],
        "type": "string",
        "description": "Represents the different types of organisations within the system."
      },
      "PaginatedResponseDtoOfUserListItemDto": {
        "required": [
          "items",
          "totalCount",
          "page",
          "pageSize"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserListItemDto"
            },
            "description": "Gets the collection of items in the current page. is a test. Love. Ather lovely test."
          },
          "totalCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the total number of items across all pages.",
            "format": "int32"
          },
          "page": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the current page number (1-based index).",
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the number of items per page.",
            "format": "int32"
          }
        },
        "description": "Represents aUpdatedon of items and pagination metadata."
      },
      "PharmaceuticalEntity": {
        "type": "string",
        "description": "Flags enum stored as integer. Only Organisation uses Both;\nUserOrgMembership and TermsAcceptance use Medicines or Vaccines only.\nRepresents the types of pharmaceutical entities."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "UpdateOrganisationDetailsDto": {
        "required": [
          "organisationName",
          "headOfficeAddress",
          "headOfficeEmail",
          "headOfficeTelephone"
        ],
        "type": "object",
        "properties": {
          "organisationName": {
            "type": "string",
            "description": "Gets or sets the name of the organisation."
          },
          "headOfficeAddress": {
            "type": "string",
            "description": "Gets or sets the head office address of the organisation."
          },
          "headOfficeEmail": {
            "type": "string",
            "description": "Gets or sets the email address of the head office."
          },
          "headOfficeTelephone": {
            "type": "string",
            "description": "Gets or sets the telephone number of the head office."
          }
        },
        "description": "Represents the data transfer object for updating organisation details."
      },
      "UpdateOrgMembershipUserRoleCommandDto": {
        "required": [
          "userRole"
        ],
        "type": "object",
        "properties": {
          "userRole": {
            "description": "Gets or initialises the user role to be updated in the organisation membership.\nThe new UserRole UpdateOrgMembershipUserRoleCommandDto.UserRole to assign to the user.",
            "$ref": "#/components/schemas/UserRole"
          }
        },
        "description": "Represents a Data Transfer Object (DTO) for updating the user role\nin an organisation membership."
      },
      "UserListItemDto": {
        "type": "object",
        "properties": {
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Gets the unique identifier of the user.",
            "format": "int32"
          },
          "emailAddress": {
            "type": [
              "null",
              "string"
            ],
            "description": "Gets the email address of the user, if available."
          },
          "role": {
            "description": "Gets the role of the user within the system.",
            "$ref": "#/components/schemas/UserRole"
          },
          "status": {
            "description": "Gets the organisational status of the user.",
            "$ref": "#/components/schemas/UserOrgStatus"
          },
          "lastActive": {
            "type": [
              "null",
              "string"
            ],
            "description": "Gets the date and time when the user was last active, if available.",
            "format": "date-time"
          }
        },
        "description": "Represents a limited summary of a user."
      },
      "UserOrgStatus": {
        "enum": [
          "RequestedAccess",
          "AwaitingSetup",
          "Active",
          "Rejected",
          "Inactive"
        ],
        "type": "string",
        "description": "Represents the status of a user's association with an organisation."
      },
      "UserRole": {
        "enum": [
          "Standard",
          "Champion",
          "Super"
        ],
        "type": "string",
        "description": "Represents the different roles a user can have within the system."
      }
    }
  },
  "tags": [
    {
      "name": "Organisation"
    },
    {
      "name": "User"
    }
  ]
}