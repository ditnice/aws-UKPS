{
  "name": "ukps-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "UKPS Frontend solution using Next.js with Payload 3",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:api": "openapi-ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "fallow": "fallow",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:style": "stylelint \"**/*.{css,scss}\"",
    "lint:check": "pnpm lint && pnpm lint:style && prettier --check .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix && stylelint \"**/*.{css,scss}\" --fix && prettier --write .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.6.1",
    "graphql": "^16.14.0",
    "next": "16.2.10",
    "payload": "3.86.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "fallow": "2.104.0",
    "jsdom": "28.1.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-order": "^8.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "^11"
  }
}
