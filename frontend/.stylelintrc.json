{
  "plugins": ["stylelint-order"],
  "extends": "stylelint-config-sass-guidelines",
  "rules": {
    "max-nesting-depth": 3,
    "order/order": [
      "dollar-variables",
      "custom-properties",
      {
        "type": "at-rule",
        "name": "include",
        "hasBlock": false
      },
      "declarations"
    ]
  }
}
