                  "value": "application/problem+json"
                }
              ],
              "body": "{\n  \"type\": \"https://tools.ietf.org/html/rfc9110#section-15.5.1\",\n  \"title\": \"One or more validation errors occurred.\",\n  \"status\": 400,\n  \"errors\": {\n    \"HeadOfficeEmail\": [\n      \"The HeadOfficeEmail field is not a valid e-mail address.\"\n    ]\n  }\n}",
