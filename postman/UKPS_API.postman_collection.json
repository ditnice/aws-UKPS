            "item": [
                {
                    "name": "Get Organisation by ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/companies/{{organisation_id}}",
                            "host": ["{{base_url}}"],
                            "path": ["companies", "{{organisation_id}}"],
                            "variable": [
                                {
                                    "key": "organisation_id",
                                    "value": "1",
                                    "description": "The integer ID of the organisation to retrieve"
                                }
                            ]
                        },
                        "description": "Retrieves core details for a single organisation by its integer ID.\n\nReturns 200 OK with organisation details, or 404 Not Found if no organisation with the given ID exists."
                    },
                    "response": [
                        {
                            "name": "200 OK - Organisation found",
                            "status": "OK",
                            "code": 200,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"id\": 1,\n    \"organisationType\": \"PharmaCompany\",\n    \"organisationName\": \"Acme Pharma Ltd\",\n    \"headOfficeAddress\": \"1 High Street, London, EC1A 1AA\",\n    \"headOfficeEmail\": \"info@acme.com\",\n    \"headOfficeTelephone\": \"020 1234 5678\"\n}",
