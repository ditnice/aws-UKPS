{
  "info": {
    "_postman_id": "ukps-api-collection",
    "name": "UKPS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5016",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Organisations",
      "item": [
        {
          "name": "Get Organisation By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/organisations/{{organisationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["organisations", "{{organisationId}}"],
              "variable": [
                {
                  "key": "organisationId",
                  "value": "1",
                  "description": "The integer ID of the organisation to retrieve"
                }
              ]
            },
            "description": "Returns the details of a single organisation by its ID. Returns 404 if no organisation with the given ID exists."
          },
          "response": [
            {
              "name": "200 OK - Organisation found",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"id\": 1,\n  \"organisationName\": \"Example Pharma Ltd\",\n  \"organisationType\": 0,\n  \"allowedPharmaceuticalEntity\": 3,\n  \"countryOrRegion\": \"United Kingdom\",\n  \"headOfficeAddress\": \"123 Example Street, London, EC1A 1BB\",\n  \"headOfficeEmail\": \"contact@examplepharma.co.uk\",\n  \"headOfficeTelephone\": \"+44 20 7946 0000\",\n  \"status\": 1,\n  \"lastActive\": \"2026-06-01T09:00:00Z\",\n  \"createdAt\": \"2025-01-15T10:30:00Z\"\n}",
              "_postman_previewlanguage": "json",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/organisations/1",
                  "host": ["{{baseUrl}}"],
                  "path": ["organisations", "1"]
                }
              }
            },
            {
              "name": "404 Not Found - Organisation does not exist",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": "",
              "_postman_previewlanguage": "text",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/organisations/9999",
                  "host": ["{{baseUrl}}"],
                  "path": ["organisations", "9999"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
